---
import Layout from "@/layouts/main.astro"
import { DashboardLayout } from "@/components/dashboard-layout"
import { getCollection } from "astro:content"
import { getNotesGroups } from "@/lib/notes"

const learningModules = await getCollection("learning")
const notes = await getNotesGroups()
---

<Layout title="Never Stop Learning">
  <DashboardLayout client:load title="Home" notes={notes}>
    <div className="mx-auto w-full max-w-3xl">
      <div className="mb-8">
        <h1 className="text-3xl font-bold tracking-tight">Never Stop Learning</h1>
        <p className="mt-2 text-muted-foreground">Notes and things I'm learning.</p>
      </div>

      <div className="space-y-1">
        {learningModules.map((module) => (
          <a
            href={`/never-stop-learning/learning/${module.id}`}
            className="group flex items-center justify-between rounded-lg px-3 py-2 -mx-3 hover:bg-accent transition-colors"
          >
            <div>
              <p className="text-sm font-medium group-hover:text-accent-foreground">{module.data.title}</p>
              <p className="text-xs text-muted-foreground">{module.data.description}</p>
            </div>
            <span className="text-muted-foreground text-xs group-hover:text-accent-foreground">→</span>
          </a>
        ))}
      </div>

      <div className="mt-8 pt-6 border-t">
        <div className="flex gap-4 text-sm text-muted-foreground">
          <a href="/never-stop-learning/notes" className="hover:text-foreground transition-colors">Notes</a>
          <a href="/never-stop-learning/about" className="hover:text-foreground transition-colors">About</a>
        </div>
      </div>
    </div>
  </DashboardLayout>
</Layout>
