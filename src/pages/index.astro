---
import Layout from "@/layouts/main.astro"
import { DashboardLayout } from "@/components/dashboard-layout"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { getCollection } from "astro:content"

const learningModules = await getCollection("learning")
---

<Layout title="Never Stop Learning">
  <DashboardLayout client:load title="Home">
    <div className="mx-auto w-full max-w-3xl space-y-4">
      <div className="rounded-xl bg-muted/50 p-8">
        <h1 className="text-2xl font-bold">Never Stop Learning</h1>
        <p className="mt-2 text-muted-foreground">A place to track what I'm learning and keep notes.</p>
      </div>

      <Card>
        <CardHeader>
          <CardTitle>Learning Modules</CardTitle>
          <CardDescription>Notes and topics I'm exploring</CardDescription>
        </CardHeader>
        <CardContent className="space-y-2">
          {learningModules.map((module) => (
            <a href={`/never-stop-learning/learning/${module.id}`} class="block rounded-lg border p-3 hover:bg-accent transition-colors">
              <p className="text-sm font-medium">{module.data.title}</p>
              <p className="text-xs text-muted-foreground">{module.data.description}</p>
            </a>
          ))}
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle>Quick Links</CardTitle>
        </CardHeader>
        <CardContent className="flex gap-2">
          <a href="/never-stop-learning/courses" className="rounded-lg border px-4 py-2 text-sm hover:bg-accent transition-colors">All Courses</a>
          <a href="/never-stop-learning/about" className="rounded-lg border px-4 py-2 text-sm hover:bg-accent transition-colors">About</a>
        </CardContent>
      </Card>
    </div>
  </DashboardLayout>
</Layout>
