---
import Layout from "@/layouts/main.astro"
import { DashboardLayout } from "@/components/dashboard-layout"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
---

<Layout title="JavaScript Fundamentals | Never Stop Learning">
  <DashboardLayout client:load title="JavaScript Fundamentals">
    <div className="mx-auto w-full max-w-3xl space-y-4">
      <Card>
        <CardHeader>
          <div className="flex items-center gap-3">
            <img src="/never-stop-learning/icons/vscode.svg" alt="" className="w-6 h-6" />
            <CardTitle>JavaScript Fundamentals</CardTitle>
          </div>
          <CardDescription>8 lessons &middot; Beginner</CardDescription>
        </CardHeader>
        <CardContent className="space-y-3">
          <p className="text-sm text-muted-foreground">
            Master variables, functions, closures, and async/await patterns. Build a solid foundation for web development.
          </p>
          <div className="space-y-2">
            <p className="text-sm font-medium">Lessons</p>
            <ol className="list-decimal list-inside space-y-1 text-sm text-muted-foreground">
              <li>Variables, Types, and Scope</li>
              <li>Functions and Closures</li>
              <li>Arrays and Objects</li>
              <li>Prototypes and Inheritance</li>
              <li>Async JavaScript: Callbacks, Promises, and Async/Await</li>
              <li>DOM Manipulation and Events</li>
              <li>Error Handling and Debugging</li>
              <li>Modules and ES6 Features</li>
            </ol>
          </div>
        </CardContent>
      </Card>
    </div>
  </DashboardLayout>
</Layout>
