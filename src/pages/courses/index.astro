---
import Layout from "@/layouts/main.astro"
import { DashboardLayout } from "@/components/dashboard-layout"
import { getCollection } from "astro:content"

const learningModules = await getCollection("learning")
---

<Layout title="Courses | Never Stop Learning">
  <DashboardLayout client:load title="Courses">
    <div className="mx-auto w-full max-w-3xl">
      <div className="mb-8">
        <h1 className="text-3xl font-bold tracking-tight">All Content</h1>
        <p className="mt-2 text-muted-foreground">Everything I'm learning and taking notes on.</p>
      </div>

      <div className="space-y-6">
        <div>
          <h2 className="text-sm font-medium text-muted-foreground mb-2">Learning Modules</h2>
          <div className="space-y-1">
            {learningModules.map((module) => (
              <a
                href={`/never-stop-learning/learning/${module.id}`}
                className="group flex items-center justify-between rounded-lg px-3 py-2 -mx-3 hover:bg-accent transition-colors"
              >
                <span className="text-sm group-hover:text-accent-foreground">{module.data.title}</span>
                <span className="text-muted-foreground text-xs group-hover:text-accent-foreground">→</span>
              </a>
            ))}
          </div>
        </div>

        <div>
          <h2 className="text-sm font-medium text-muted-foreground mb-2">Courses</h2>
          <div className="space-y-1">
            <a href="/never-stop-learning/courses/javascript-fundamentals" className="group flex items-center justify-between rounded-lg px-3 py-2 -mx-3 hover:bg-accent transition-colors">
              <span className="text-sm group-hover:text-accent-foreground">JavaScript Fundamentals</span>
              <span className="text-muted-foreground text-xs group-hover:text-accent-foreground">→</span>
            </a>
            <a href="/never-stop-learning/courses/react-deep-dive" className="group flex items-center justify-between rounded-lg px-3 py-2 -mx-3 hover:bg-accent transition-colors">
              <span className="text-sm group-hover:text-accent-foreground">React Deep Dive</span>
              <span className="text-muted-foreground text-xs group-hover:text-accent-foreground">→</span>
            </a>
            <a href="/never-stop-learning/courses/system-design" className="group flex items-center justify-between rounded-lg px-3 py-2 -mx-3 hover:bg-accent transition-colors">
              <span className="text-sm group-hover:text-accent-foreground">System Design</span>
              <span className="text-muted-foreground text-xs group-hover:text-accent-foreground">→</span>
            </a>
            <a href="/never-stop-learning/courses/css-mastery" className="group flex items-center justify-between rounded-lg px-3 py-2 -mx-3 hover:bg-accent transition-colors">
              <span className="text-sm group-hover:text-accent-foreground">CSS Mastery</span>
              <span className="text-muted-foreground text-xs group-hover:text-accent-foreground">→</span>
            </a>
            <a href="/never-stop-learning/courses/python-for-everyone" className="group flex items-center justify-between rounded-lg px-3 py-2 -mx-3 hover:bg-accent transition-colors">
              <span className="text-sm group-hover:text-accent-foreground">Python for Everyone</span>
              <span className="text-muted-foreground text-xs group-hover:text-accent-foreground">→</span>
            </a>
            <a href="/never-stop-learning/courses/security-essentials" className="group flex items-center justify-between rounded-lg px-3 py-2 -mx-3 hover:bg-accent transition-colors">
              <span className="text-sm group-hover:text-accent-foreground">Security Essentials</span>
              <span className="text-muted-foreground text-xs group-hover:text-accent-foreground">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </DashboardLayout>
</Layout>
