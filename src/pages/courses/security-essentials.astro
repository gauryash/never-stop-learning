---
import Layout from "@/layouts/main.astro"
import { DashboardLayout } from "@/components/dashboard-layout"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
---

<Layout title="Security Essentials | Never Stop Learning">
  <DashboardLayout client:load title="Security Essentials">
    <div className="mx-auto w-full max-w-3xl space-y-4">
      <Card>
        <CardHeader>
          <CardTitle>Security Essentials</CardTitle>
          <CardDescription>8 lessons &middot; Intermediate</CardDescription>
        </CardHeader>
        <CardContent className="space-y-3">
          <p className="text-sm text-muted-foreground">
            Understand the most common security vulnerabilities and how to defend against them.
          </p>
          <div className="space-y-2">
            <p className="text-sm font-medium">Lessons</p>
            <ol className="list-decimal list-inside space-y-1 text-sm text-muted-foreground">
              <li>Introduction to Application Security</li>
              <li>OWASP Top 10 Overview</li>
              <li>SQL Injection and XSS Prevention</li>
              <li>Authentication and Session Management</li>
              <li>Cryptography Basics</li>
              <li>HTTPS and Transport Security</li>
              <li>Access Control and Authorization</li>
              <li>Secure Development Lifecycle</li>
            </ol>
          </div>
        </CardContent>
      </Card>
    </div>
  </DashboardLayout>
</Layout>
