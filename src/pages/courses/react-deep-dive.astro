---
import Layout from "@/layouts/main.astro"
import { DashboardLayout } from "@/components/dashboard-layout"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
---

<Layout title="React Deep Dive | Never Stop Learning">
  <DashboardLayout client:load title="React Deep Dive">
    <div className="mx-auto w-full max-w-3xl space-y-4">
      <Card>
        <CardHeader>
          <CardTitle>React Deep Dive</CardTitle>
          <CardDescription>12 lessons &middot; Intermediate</CardDescription>
        </CardHeader>
        <CardContent className="space-y-3">
          <p className="text-sm text-muted-foreground">
            Go beyond the basics. Explore hooks in depth, state management strategies, rendering performance, and battle-tested patterns.
          </p>
          <div className="space-y-2">
            <p className="text-sm font-medium">Lessons</p>
            <ol className="list-decimal list-inside space-y-1 text-sm text-muted-foreground">
              <li>Component Patterns and Composition</li>
              <li>Hooks: useState, useEffect, and Beyond</li>
              <li>Custom Hooks and Logic Reuse</li>
              <li>Context API and State Management</li>
              <li>Performance: Memoization and Lazy Loading</li>
              <li>Server Components and Streaming</li>
              <li>Forms and Validation</li>
              <li>Testing React Components</li>
              <li>Routing and Navigation</li>
              <li>Data Fetching and Caching</li>
              <li>Error Boundaries and Resilience</li>
              <li>Deploying React Applications</li>
            </ol>
          </div>
        </CardContent>
      </Card>
    </div>
  </DashboardLayout>
</Layout>
