---
import Layout from "@/layouts/main.astro"
import { DashboardLayout } from "@/components/dashboard-layout"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
---

<Layout title="CSS Mastery | Never Stop Learning">
  <DashboardLayout client:load title="CSS Mastery">
    <div className="mx-auto w-full max-w-3xl space-y-4">
      <Card>
        <CardHeader>
          <CardTitle>CSS Mastery</CardTitle>
          <CardDescription>6 lessons &middot; Beginner</CardDescription>
        </CardHeader>
        <CardContent className="space-y-3">
          <p className="text-sm text-muted-foreground">
            Master modern CSS layout techniques including Flexbox, Grid, animations, and responsive design.
          </p>
          <div className="space-y-2">
            <p className="text-sm font-medium">Lessons</p>
            <ol className="list-decimal list-inside space-y-1 text-sm text-muted-foreground">
              <li>CSS Selectors and Specificity</li>
              <li>Flexbox Layout</li>
              <li>CSS Grid</li>
              <li>Responsive Design and Media Queries</li>
              <li>Animations and Transitions</li>
              <li>CSS Custom Properties and Theming</li>
            </ol>
          </div>
        </CardContent>
      </Card>
    </div>
  </DashboardLayout>
</Layout>
