---
import Layout from "@/layouts/main.astro"
import { DashboardLayout } from "@/components/dashboard-layout"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
---

<Layout title="Python for Everyone | Never Stop Learning">
  <DashboardLayout client:load title="Python for Everyone">
    <div className="mx-auto w-full max-w-3xl space-y-4">
      <Card>
        <CardHeader>
          <div className="flex items-center gap-3">
            <img src="/never-stop-learning/icons/obsidian.svg" alt="" className="w-6 h-6" />
            <CardTitle>Python for Everyone</CardTitle>
          </div>
          <CardDescription>10 lessons &middot; Beginner</CardDescription>
        </CardHeader>
        <CardContent className="space-y-3">
          <p className="text-sm text-muted-foreground">
            Learn Python from scratch. Covers syntax, data structures, file I/O, and real-world scripting projects.
          </p>
          <div className="space-y-2">
            <p className="text-sm font-medium">Lessons</p>
            <ol className="list-decimal list-inside space-y-1 text-sm text-muted-foreground">
              <li>Python Basics and Syntax</li>
              <li>Variables and Data Types</li>
              <li>Control Flow and Loops</li>
              <li>Functions and Modules</li>
              <li>Data Structures: Lists, Dicts, Sets</li>
              <li>File I/O and Error Handling</li>
              <li>List Comprehensions and Generators</li>
              <li>Working with APIs</li>
              <li>Data Processing with Python</li>
              <li>Building CLI Tools</li>
            </ol>
          </div>
        </CardContent>
      </Card>
    </div>
  </DashboardLayout>
</Layout>
