---
import Layout from "@/layouts/main.astro"
import { DashboardLayout } from "@/components/dashboard-layout"
import { getCollection } from "astro:content"

const learningModules = await getCollection("learning")
const groupMap = new Map<string, { name: string; url: string }[]>()
for (const m of learningModules) {
  const group = m.data.group ?? "General"
  if (!groupMap.has(group)) groupMap.set(group, [])
  groupMap.get(group)!.push({ name: m.data.title, url: `/never-stop-learning/learning/${m.id}` })
}
const notes = [...groupMap.entries()].map(([name, modules]) => ({ name, modules }))
---

<Layout title="About | Never Stop Learning">
  <DashboardLayout client:load title="About" notes={notes}>
    <div className="mx-auto w-full max-w-3xl">
      <div className="mb-8">
        <h1 className="text-3xl font-bold tracking-tight">About</h1>
      </div>

      <div className="space-y-4 text-sm text-muted-foreground leading-relaxed">
        <p>
          This is my personal space for learning new things and keeping notes. I write down what I learn as I go through tutorials, books, and projects.
        </p>
        <p>
          Built with Astro, React, Tailwind, and shadcn/ui. Notes are written in Markdown.
        </p>
      </div>
    </div>
  </DashboardLayout>
</Layout>
