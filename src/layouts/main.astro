---
import "@/styles/global.css"

interface Props {
  title?: string
  description?: string
}

const { title = "Never Stop Learning", description = "A platform for lifelong learners" } = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/never-stop-learning/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
