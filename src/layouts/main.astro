---
import "@/styles/global.css"

interface Props {
  title?: string
}

const { title = "Never Stop Learning" } = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preload" href="/never-stop-learning/fonts/Satoshi-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/never-stop-learning/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-svh bg-background font-sans antialiased">
    <slot />
  </body>
</html>
